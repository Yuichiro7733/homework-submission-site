rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /materials/{materialId} {
      allow create: if signedIn()
        && request.resource.data.submitterUid == request.auth.uid
        && request.resource.data.status == 'sent'
        && request.resource.data.fileType == 'image/jpeg'
        && request.resource.data.keys().hasAll([
          'submitterUid',
          'fileName',
          'fileType',
          'storagePath',
          'status',
          'submittedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'submitterUid',
          'fileName',
          'fileType',
          'storagePath',
          'status',
          'submittedAt'
        ]);
      allow read: if signedIn();
      allow update: if signedIn()
        && request.resource.data.submitterUid == resource.data.submitterUid
        && request.resource.data.storagePath == resource.data.storagePath
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'confirmedAt'
        ]);
      allow delete: if false;
    }
  }
}
